# Postgres (Vercel Postgres o Neon). DATABASE_URL = conexión con pooling,
# DIRECT_URL = conexión directa (la usa `prisma db push`/migrate).
DATABASE_URL="postgresql://usuario:password@host/db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://usuario:password@host/db?sslmode=require"

# Vercel Blob (almacenamiento de los PDF subidos). Se genera solo al conectar
# un Blob Store al proyecto en Vercel; en local cópialo desde el dashboard.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5
